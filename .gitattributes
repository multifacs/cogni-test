# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files that should always use LF
*.svelte text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.svg text eol=lf

# Binary files — no normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.webp binary
*.zip binary
*.gz binary
*.onnx binary

# Lock files
bun.lockb binary
package-lock.json text eol=lf

# Database files
*.db binary
*.sqlite binary
