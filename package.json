{
	"name": "cogni-test",
	"private": true,
	"version": "0.7.0",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"init-db": "npx drizzle-kit push --force",
		"start": "npx drizzle-kit push --force && node index.js",
		"preview": "cross-env MODE=LOCAL DATABASE_URL=file:sqlite.db vite preview --host",
		"init-db-dev": "cross-env DATABASE_URL=file:sqlite.db npx drizzle-kit push --force",
		"dev": "cross-env DATABASE_URL=file:sqlite.db vite dev",
		"host": "cross-env MODE=LOCAL DATABASE_URL=file:sqlite.db vite --host",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"prepare": "svelte-kit sync || echo ''",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/js": "^10.0.1",
		"@fontsource/roboto": "^5.2.10",
		"@playwright/test": "^1.60.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24.13.2",
		"@vitest/browser-playwright": "^4.1.8",
		"better-auth": "~1.4.21",
		"cross-env": "^10.1.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vite-plugin-mkcert": "^2.1.0",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"workbox-cacheable-response": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-routing": "^7.4.1",
		"workbox-strategies": "^7.4.1"
	},
	"dependencies": {
		"@fontsource/comic-neue": "^5.2.7",
		"@fontsource/fira-code": "^5.2.7",
		"@libsql/client": "^0.17.3",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@types/web-push": "^3.6.4",
		"chart.js": "^4.5.1",
		"chartjs-plugin-annotation": "^3.1.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"gray-matter": "^4.0.3",
		"localforage": "^1.10.0",
		"onnxruntime-node": "^1.26.0",
		"short-uuid": "^6.0.3",
		"uuid": "^14.0.0",
		"web-push": "^3.6.7"
	},
	"allowScripts": {
		"esbuild@0.18.20": true,
		"esbuild@0.25.12": true,
		"esbuild@0.28.1": true,
		"@prisma/client@5.22.0": true,
		"better-sqlite3@12.10.0": true,
		"onnxruntime-node@1.26.0": true
	}
}
